    {
      "name": "Forget Password APIs",
      "item": [
        {
          "name": "Forget Password (Send OTP)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/users/forget-password",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["users", "forget-password"]
            }
          }
        },
        {
          "name": "Reset Password (Verify OTP)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"1234\",\n  \"new_password\": \"newpassword123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/users/reset-password",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["users", "reset-password"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "jwt_token",
