              "raw": "{\n  \"not_id\": 123,\n  \"title\": \"Updated Product Launch!\",\n  \"description\": \"Updated description for our products\",\n  \"is_active\": false,\n  \"offer_image\": \"https://example.com/updated-notification.jpg\"\n}"
