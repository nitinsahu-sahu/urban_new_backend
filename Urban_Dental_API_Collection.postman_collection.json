          "name": "Create Notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Product Launch!\",\n  \"description\": \"Check out our latest dental care products\",\n  \"is_active\": true,\n  \"offer_image\": \"https://example.com/notification.jpg\"\n}"
