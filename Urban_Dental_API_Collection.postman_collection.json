{
  "info": {
    "name": "Urban Dental API Collection - Complete CRUD APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete collection of all CRUD APIs created today including Home Banner, Product Offers, Notification, and Forget Password"
  },
  "item": [
    {
      "name": "Home Banner APIs",
      "item": [
        {
          "name": "Get Home Banners",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/home_banner?page=1&limit=10&banner_id=123&search=banner",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["home_banner"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "banner_id",
                  "value": "123"
                },
                {
                  "key": "search",
                  "value": "banner"
                }
              ]
            }
          }
        },
        {
          "name": "Create Home Banner",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": true,\n  \"banners\": \"https://example.com/banner.jpg\",\n  \"title\": \"Welcome Banner\",\n  \"description\": \"Main homepage banner\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/home_banner",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["home_banner"]
            }
          }
        },
        {
          "name": "Update Home Banner",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"banner_id\": 123,\n  \"is_active\": false,\n  \"banners\": \"https://example.com/updated-banner.jpg\",\n  \"title\": \"Updated Title\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/home_banner",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["home_banner"]
            }
          }
        },
        {
          "name": "Delete Home Banner",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/home_banner/123",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["home_banner", "123"]
            }
          }
        }
      ]
    },
    {
