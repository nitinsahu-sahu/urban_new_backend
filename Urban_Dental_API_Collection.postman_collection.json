    {
      "name": "Notification APIs",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/notification?is_active=true&page=1&limit=10&search=product",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["notification"],
              "query": [
                {
                  "key": "is_active",
                  "value": "true"
                },
                {
                  "key": "page",
